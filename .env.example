# Database (local Docker)
POSTGRES_PASSWORD="your-database-password-generate-with-openssl-rand-base64-32"
DATABASE_URL="postgresql://prunebox:prunebox@localhost:5432/prunebox"

# Redis (for BullMQ job queue)
# Required for background job processing (email scanning, unsubscription, bulk deletion, rollup digests)
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Gmail API Scopes (Restricted - requires verification)
# gmail.readonly - Read email headers for subscription detection
# gmail.modify - Move emails, apply labels, trash messages
# gmail.labels - Create/manage subscription labels
# gmail.send - Send rollup digest emails
GOOGLE_OAUTH_SCOPES="gmail.readonly gmail.modify gmail.labels gmail.send"

# Encryption
# REQUIRED: Generate a secure encryption key for OAuth tokens at rest
# Generate with: openssl rand -base64 48
# This key encrypts access_token and refresh_token in the database
# WARNING: Changing this key will make existing encrypted tokens unreadable
# Keep this key secret and rotate it securely using the provided migration script
ENCRYPTION_KEY="your-32-character-encryption-key-for-refresh-tokens"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Prunebox"

# Webhook Security
# Generate with: openssl rand -base64 32
GMAIL_WEBHOOK_SECRET="your-webhook-secret-here-generate-with-openssl-rand-base64-32"

# Rollup Digest
ROLLUP_FROM_EMAIL="noreply@yourdomain.com"
ROLLUP_FROM_NAME="Prunebox Digest"

# Rate Limits (per user)
MAX_FREE_UNSUBSCRIBES=10
FREE_SCAN_LIMIT=1000

# Email Scan Limits (maximum messages to scan per job)
MAX_EMAIL_SCAN_LIMIT=1000
MAX_FULL_SCAN_LIMIT=5000

# Google Analytics (removed - privacy-first, no tracking)
