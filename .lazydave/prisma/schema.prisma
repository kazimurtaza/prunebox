generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  access_token      String?
  refresh_token     String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  profileJson       String?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified String?
  accounts      Account[]
  subscriptions Subscription[]
  preferences   SubscriptionPreference[]
  rollupSettings RollupSettings?
  syncState     GmailSyncState?
  
 Cascade UnsubscriptionAttempt[]

  Cascade BulkDeletionJob[]
}

model Subscription {
  id         String   @id @default(cuid())
  userId     String
  senderEmail String
  senderName String?
  lastEmailSubject String?
  lastEmailSnippet String?
  confidenceScore Int?
  unsubscribeUrl String?
  unsubscribeMailto String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferences SubscriptionPreference[]
  
  @@unique([userId, senderEmail])
}

model SubscriptionPreference {
  id            String   @id @default(cuid())
  userId        String
  subscriptionId String
  action        String   // 'keep', 'unsubscribe', 'rollup'
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription  Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  @@unique([userId, subscriptionId, action])
}

model RollupSettings {
  id           String      @id @default(cuid())
  userId       String
  enabled      Boolean     @default(false)
  deliverySlot DeliverySlot @default(MORNING)
  timezone     String      @default('UTC')
  digestName   String      @default('My Daily Rollup')
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId])
}

model GmailSyncState {
  id           String     @id @default(cuid())
  userId       String
  scanStatus   ScanStatus @default(IDLE)
  scanProgress Int
  scanTotal    Int
  errorMessage String?
  lastSyncedAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ScanStatus {
  IDLE
  SCANNING
  COMPLETED
  FAILED
}

enum DeliverySlot {
  MORNING
  AFTERNOON
  EVENING
}
