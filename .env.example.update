# =============================================================================
# PRUNEBOX ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains all the environment variables needed to run Prunebox.
# Copy this file to .env and fill in the actual values.
#
# Setup Instructions: https://console.cloud.google.com/
# Detailed Guide: docs/GOOGLE_OAUTH_SETUP.md
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
# Local Docker PostgreSQL database connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://prunebox:prunebox@localhost:5432/prunebox"

# Docker setup command:
# docker run --name prunebox-db -e POSTGRES_USER=prunebox -e POSTGRES_PASSWORD=prunebox -e POSTGRES_DB=prunebox -p 5432:5432 -d postgres:15

# -----------------------------------------------------------------------------
# REDIS (BullMQ Job Queue)
# -----------------------------------------------------------------------------
# Local Docker Redis connection string
REDIS_URL="redis://localhost:6379"

# Docker setup command:
# docker run --name prunebox-redis -p 6379:6379 -d redis:7-alpine

# -----------------------------------------------------------------------------
# NEXTAUTH CONFIGURATION
# -----------------------------------------------------------------------------
# The URL where your app is running (include protocol and port)
# For local development:
NEXTAUTH_URL="http://localhost:3000"
# For production:
# NEXTAUTH_URL="https://yourdomain.com"

# Secret key for NextAuth.js session encryption
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# -----------------------------------------------------------------------------
# GOOGLE OAUTH 2.0 CREDENTIALS (REQUIRED FOR LOGIN)
# -----------------------------------------------------------------------------
# ⚠️ YOU MUST CREATE YOUR OWN CREDENTIALS - PLACEHOLDERS WILL NOT WORK
#
# Quick Setup Guide:
# 1. Go to: https://console.cloud.google.com/
# 2. Create a new project (or select existing)
# 3. Enable "Gmail API" (APIs & Services > Library)
# 4. Configure OAuth consent screen (APIs & Services > OAuth consent screen)
# 5. Create OAuth 2.0 Client ID (APIs & Services > Credentials)
# 6. Add redirect URI: http://localhost:3000/api/auth/callback/google
# 7. Copy Client ID and Client Secret below
#
# Detailed Setup Guide: docs/GOOGLE_OAUTH_SETUP.md

# Your Google OAuth 2.0 Client ID
# Format: XXXXXXXX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Your Google OAuth 2.0 Client Secret
# This is only shown once - save it securely
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# -----------------------------------------------------------------------------
# GMAIL API SCOPES
# -----------------------------------------------------------------------------
# Gmail API scopes required by the application
# These are "Restricted" scopes that require Google verification for production
#
# Scope descriptions:
# - gmail.readonly  : Read email headers for subscription detection
# - gmail.modify    : Move emails, apply labels, trash messages
# - gmail.labels   : Create/manage subscription labels
# - gmail.send     : Send rollup digest emails
#
# Note: For development, add yourself as a test user in OAuth consent screen
GOOGLE_OAUTH_SCOPES="gmail.readonly gmail.modify gmail.labels gmail.send"

# -----------------------------------------------------------------------------
# ENCRYPTION
# -----------------------------------------------------------------------------
# 32-character encryption key for securing refresh tokens at rest
# Generate with: openssl rand -base64 24 | head -c32
ENCRYPTION_KEY="your-32-character-encryption-key-for-refresh-tokens"

# -----------------------------------------------------------------------------
# APP CONFIGURATION
# -----------------------------------------------------------------------------
# Public URL of your application (used for links and redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Application name (displayed in UI, emails, etc.)
NEXT_PUBLIC_APP_NAME="Prunebox"

# -----------------------------------------------------------------------------
# ROLLUP DIGEST EMAILS
# -----------------------------------------------------------------------------
# From address for digest emails
# Note: For production, use a verified domain email
ROLLUP_FROM_EMAIL="noreply@yourdomain.com"

# From name for digest emails
ROLLUP_FROM_NAME="Prunebox Digest"

# -----------------------------------------------------------------------------
# RATE LIMITS (Free Tier)
# -----------------------------------------------------------------------------
# Maximum number of free unsubscribes per user
MAX_FREE_UNSUBSCRIBES=10

# Maximum number of emails to scan for free tier users
FREE_SCAN_LIMIT=1000

# =============================================================================
# SETUP CHECKLIST
# =============================================================================
#
# Before running the application, ensure you have:
#
# [ ] 1. Created Google Cloud Project
#       -> https://console.cloud.google.com/
#
# [ ] 2. Enabled Gmail API
#       -> APIs & Services > Library > Gmail API > Enable
#
# [ ] 3. Configured OAuth Consent Screen
#       -> APIs & Services > OAuth consent screen
#       -> Add scopes: openid, email, profile, gmail.readonly, gmail.modify,
#                      gmail.labels, gmail.send
#       -> Add your email as test user (for development)
#
# [ ] 4. Created OAuth 2.0 Credentials
#       -> APIs & Services > Credentials > Create OAuth client ID
#       -> Type: Web application
#       -> Authorized redirect URI: http://localhost:3000/api/auth/callback/google
#       -> Copy Client ID and Client Secret to this file
#
# [ ] 5. Generated NEXTAUTH_SECRET
#       -> openssl rand -base64 32
#
# [ ] 6. Generated ENCRYPTION_KEY
#       -> openssl rand -base64 24 | head -c32
#
# [ ] 7. Set up PostgreSQL database
#       -> docker run --name prunebox-db -e POSTGRES_USER=prunebox \
#                       -e POSTGRES_PASSWORD=prunebox \
#                       -e POSTGRES_DB=prunebox \
#                       -p 5432:5432 -d postgres:15
#
# [ ] 8. Set up Redis
#       -> docker run --name prunebox-redis -p 6379:6379 -d redis:7-alpine
#
# [ ] 9. Run database migrations
#       -> npm run db:push
#
# [ ] 10. Start the development server
#       -> npm run dev
#
# =============================================================================
# NEED HELP?
# =============================================================================
# - Full Setup Guide: docs/GOOGLE_OAUTH_SETUP.md
# - Google Cloud Console: https://console.cloud.google.com/
# - Gmail API Docs: https://developers.google.com/gmail/api
# - NextAuth.js Docs: https://next-auth.js.org/
# =============================================================================
